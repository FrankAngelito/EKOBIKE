<?xml version="1.0" encoding="utf-8"?>
<!-- ScrollView: permite hacer scroll si el contenido no cabe en pantallas pequeñas.
     Regla importante: un ScrollView solo puede tener UN hijo directo (el LinearLayout). -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp">

        <!-- Título de la pantalla -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Crear cuenta"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Completa tus datos para registrarte"
            android:textSize="16sp"
            android:textColor="#757575"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

        <!-- Etiqueta + campo: Nombre -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nombre completo"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/edtNombre"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:background="#FFFFFF"
            android:hint="Pepito Perez"
            android:inputType="textPersonName"
            android:padding="16dp" />

        <!-- Etiqueta + campo: Correo -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Correo electrónico"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/edtCorreo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: correo@ejemplo.com"
            android:inputType="textEmailAddress"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Etiqueta + campo: Contraseña -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Contraseña"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/edtPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Mínimo 6 caracteres"
            android:inputType="textPassword"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Etiqueta + campo: Teléfono -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Teléfono"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/edtTelefono"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Ej: 0991234567"
            android:inputType="phone"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="32dp" />

        <!-- Botón de registro -->
        <Button
            android:id="@+id/btnRegistrarse"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Registrarse"
            android:textSize="16sp"
            android:backgroundTint="#2E7D32"
            android:textColor="#FFFFFF"
            android:padding="14dp" />

        <!-- Enlace de regreso al login -->
        <TextView
            android:id="@+id/txtIrLogin"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="¿Ya tienes cuenta? Inicia sesión"
            android:textColor="#2E7D32"
            android:textSize="14sp"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="24dp"
            android:clickable="true" />

    </LinearLayout>

</ScrollView>