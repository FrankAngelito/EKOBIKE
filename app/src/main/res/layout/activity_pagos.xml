<?xml version="1.0" encoding="utf-8"?>
<!-- Pagos: ingresar tarjeta (número, fecha, CVV) y guardar método de pago -->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="28dp">

        <!-- Título -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Método de pago"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:layout_marginTop="20dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ingresa los datos de tu tarjeta"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="28dp" />

        <!-- Tarjeta visual simulada -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#2E7D32"
            android:padding="24dp"
            android:layout_marginBottom="28dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Tarjeta de crédito"
                android:textSize="14sp"
                android:textColor="#C8E6C9" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="**** **** **** 1234"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:layout_marginTop="16dp" />

        </LinearLayout>

        <!-- Etiqueta + campo: número de tarjeta -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Número de tarjeta"
            android:textSize="14sp"
            android:textColor="#424242"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/edtNumeroTarjeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="1234 5678 9012 3456"
            android:inputType="number"
            android:background="#FFFFFF"
            android:padding="16dp"
            android:layout_marginBottom="16dp" />

        <!-- Fila con dos campos lado a lado: fecha y CVV -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <!-- Fecha de vencimiento (izquierda) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginEnd="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vencimiento"
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/edtVencimiento"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="MM/AA"
                    android:inputType="number"
                    android:background="#FFFFFF"
                    android:padding="16dp" />

            </LinearLayout>

            <!-- CVV (derecha) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="8dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CVV"
                    android:textSize="14sp"
                    android:textColor="#424242"
                    android:layout_marginBottom="6dp" />

                <EditText
                    android:id="@+id/edtCvv"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="123"
                    android:inputType="numberPassword"
                    android:background="#FFFFFF"
                    android:padding="16dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- Botón guardar -->
        <Button
            android:id="@+id/btnGuardarPago"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar método de pago"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2E7D32"
            android:padding="14dp" />

    </LinearLayout>

</ScrollView>