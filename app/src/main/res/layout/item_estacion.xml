<?xml version="1.0" encoding="utf-8"?>
<!-- Molde de UNA estación en la lista. Se repite por cada estación.
     Estructura: [nombre estación + bicis] a la izquierda, [cantidad grande] a la derecha -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="#FFFFFF"
    android:padding="18dp"
    android:layout_margin="6dp">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/txtNombreEstacion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cumbayá"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#1F1F1F" />

        <TextView
            android:id="@+id/txtBicisDisponibles"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="bicicletas disponibles"
            android:textSize="14sp"
            android:textColor="#757575"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:id="@+id/txtCantidad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="7"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#2E7D32" />

</LinearLayout>